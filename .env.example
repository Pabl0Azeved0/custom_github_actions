# Local-run configuration for the PR reviewer (GitHub Actions supplies these as INPUT_* at runtime).
# The code reads INPUT_<NAME> first, then these bare names as a fallback for local runs.

# Provider key (never commit the real value).
LLM_API_KEY=

# Pluggable provider (default: groq).
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Token to read the PR and post comments (a PAT for local runs).
GITHUB_TOKEN=

# Review tuning.
STRICTNESS=balanced
MAX_FINDINGS=10
MAX_DIFF_BYTES=60000
FAIL_ON_FINDINGS=false

# Optional Slack summary webhook.
SLACK_WEBHOOK=
