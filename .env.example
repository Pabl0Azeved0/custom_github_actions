# Local-run configuration for the PR reviewer (GitHub Actions supplies these as INPUT_* at runtime).
# These bare names are read ONLY on explicit local runs. Export the opt-in in your shell first:
#
#     export PR_REVIEWER_LOCAL=1
#
# It must be set in the environment, not here — this file is only read once the flag is already
# on. The Action ignores this file entirely and uses INPUT_* only.

# Provider key (never commit the real value).
LLM_API_KEY=

# Pluggable provider (default: groq).
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Token to read the PR and post comments (a PAT for local runs).
GITHUB_TOKEN=

# Review tuning.
STRICTNESS=balanced
MAX_FINDINGS=10
MAX_DIFF_BYTES=60000
FAIL_ON_FINDINGS=false

# Optional Slack summary webhook.
SLACK_WEBHOOK=
